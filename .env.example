# Optional. If unset, the app runs against an in-memory store (great for dev).
# In production, set this to your Railway Postgres connection string.
DATABASE_URL=

# Bar trading hours, local time (Australia/Adelaide).
TRADING_OPEN=16:00
TRADING_CLOSE=02:00

# GST rate (Australia: 0.10). Locked in admin UI by default.
GST_RATE=0.10

# Business identity printed on every receipt. Required for ATO-compliant
# tax invoices over $82.50.
BUSINESS_NAME=The Drink Exchange Pty Ltd
BUSINESS_ABN=00 000 000 000
BUSINESS_ADDRESS=Adelaide, South Australia

# Initial seed PINs hashed into the in-memory staff store. CHANGE THESE
# BEFORE LAUNCH and consider managing staff via /admin/staff instead.
SEED_OWNER_PIN=9999
SEED_MANAGER_PIN=5678
SEED_STAFF_PIN=1234

# Payment provider. simulated | stripe | square
PAYMENT_PROVIDER=simulated
STRIPE_SECRET_KEY=
STRIPE_TERMINAL_READER_ID=

# Receipt provider. console | twilio | postmark
RECEIPT_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
POSTMARK_TOKEN=

# Social crash webhook secret. Override to rotate.
CRASH_WEBHOOK_TOKEN=dev-webhook-token

# Observability
SENTRY_DSN=
